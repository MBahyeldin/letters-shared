generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Letter {
  id          String   @id @default(cuid())
  title       String
  contentJson Json     @default("[]")
  contentHtml String   @default("")
  author      String
  letterDate  DateTime
  position    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("letters")
}
